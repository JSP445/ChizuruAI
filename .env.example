# Discord Bot Token - Get yours at https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Ollama Server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Model name (must match `ollama list` output)
MODEL_NAME=qwen3.5:27b

# Bot personality / system prompt
SYSTEM_PROMPT=You are Chizuru, a helpful and friendly AI assistant. You engage naturally in conversations, answer questions thoughtfully, and have a warm personality. Keep responses concise and conversational unless asked for detailed explanations.

# Max tokens for model response
MAX_TOKENS=1024

# Temperature (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.7

# Max conversation history per user (number of message pairs to remember)
MAX_HISTORY=20
